{
  "languages": {
    "Nix": {
      "tab_size": 2,
      "language_servers": ["nixd", "!nil"],
      "formatter": {
        "external": {
          "command": "alejandra",
          "arguments": ["--quiet"]
        }
      }
    },
    "Rust": {
      "language_servers": ["rust-analyzer"],
      "format_on_save": "on"
    },
    "Svelte": {
      "language_servers": ["svelte-language-server"],
      "formatter": "prettier"
    }
  },
  "lsp": {
    "rust-analyzer": {
      "binary": {
        "ignore_system_version": false,
        "path": "rust-analyzer",
        "arguments": []
      },
      "initialization_options": {
        "checkOnSave": true,
        "check": {
          "command": "clippy"
        }
      }
    },
    "eslint": {
      "binary": {
        "ignore_system_version": false,
        "path": "frontend/node_modules/.bin/eslint"
      },
      "initialization_options": {
        "workingDirectory": { "mode": "location" }
      }
    },
    "svelte-language-server": {
      "binary": {
        "ignore_system_version": false,
        "path": "frontend/node_modules/.bin/svelteserver",
        "arguments": ["--stdio"]
      }
    }
  }
}
